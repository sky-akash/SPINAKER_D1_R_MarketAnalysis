   "source": [
    "# This R environment comes with many helpful analytics packages installed\n",
    "# It is defined by the kaggle/rstats Docker image: https://github.com/kaggle/docker-rstats\n",
    "\n",
    "library(tidyverse)\n",
    "\n",
    "input_dir <- \"/kaggle/input/datasets/thecielo/olist-spinaker\"\n",
    "input_files <- list.files(input_dir, full.names = TRUE)\n",
    "csv_files <- input_files[tools::file_ext(input_files) == \"csv\"]\n",
    "\n",
    "csv_files\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "datasets <- csv_files %>%\n",
    "  set_names(tools::file_path_sans_ext(basename(csv_files))) %>%\n",
    "  map(~ read_csv(.x, show_col_types = FALSE))\n",
    "\n",
    "dataset_overview <- tibble(\n",
    "  file = names(datasets),\n",
    "  rows = map_int(datasets, nrow),\n",
    "  columns = map_int(datasets, ncol),\n",
    "  missing_values = map_int(datasets, ~ sum(is.na(.x))),\n",
    "  duplicate_rows = map_int(datasets, ~ sum(duplicated(.x)))\n",
    ")\n",
    "\n",
    "dataset_overview\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "explore_dataset <- function(data, file_name) {\n",
    "  cat(\"\\n========================================\\n\")\n",
    "  cat(\"File:\", file_name, \"\\n\")\n",
    "  cat(\"Rows:\", nrow(data), \"Columns:\", ncol(data), \"\\n\")\n",
    "  cat(\"Column summary:\\n\")\n",
    "  column_summary <- tibble(\n",
    "    column = names(data),\n",
    "    class = map_chr(data, ~ paste(class(.x), collapse = \", \")),\n",
    "    missing = map_int(data, ~ sum(is.na(.x))),\n",
    "    unique_values = map_int(data, ~ n_distinct(.x))\n",
    "  )\n",
    "  print(column_summary)\n",
    "  cat(\"Preview:\\n\")\n",
    "  print(head(data, 5))\n",
    "}\n",
    "\n",
    "walk2(datasets, names(datasets), explore_dataset)\n"
   ]
